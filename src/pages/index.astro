---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Plombier Charleroi | Urgence & Dépannage 24/7">
  <!-- Hero Section -->
  <section class="hero">
    <div class="hero-bg-shape"></div>
    <div class="container hero-container grid">
      <div class="hero-content">
        <span class="badge">Service 24/7 à Charleroi</span>
        <h1>Ne laissez pas une fuite gâcher votre journée, <span class="text-primary">appelez-nous</span></h1>
        <p>Expert local en plomberie, débouchage et chauffage. Intervention rapide, travail de qualité et tarifs transparents. Vos problèmes de tuyauterie résolus en un clin d'œil.</p>
        <div class="hero-actions flex gap-4 items-center mt-8">
          <a href="tel:0479123456" class="btn btn-primary">Appelez-nous</a>
          <a href="/contact" class="btn btn-secondary">Demander un Devis</a>
        </div>
      </div>
      <div class="hero-image">
        <div class="image-wrapper">
          <img src="/images/hero.png" alt="Plombier professionnel à Charleroi" />
          <div class="stats-float card">
            <div class="flex items-center gap-4">
              <div class="stats-icon text-primary text-2xl">👨‍🔧</div>
              <div>
                <h4 class="text-primary text-xl">3000+</h4>
                <p class="text-sm">Clients Satisfaits</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Features Section -->
  <section class="section features">
    <div class="container">
      <div class="text-center mb-12">
        <span class="text-primary font-bold tracking-wider uppercase text-sm">Pourquoi nous choisir</span>
        <h2>Notre Expertise</h2>
      </div>
      <div class="grid feature-grid">
        <div class="card feature-card">
          <div class="icon-wrapper">🚀</div>
          <h3>Service Rapide</h3>
          <p>Intervention dans l'heure pour toutes vos urgences sur la région de Charleroi.</p>
        </div>
        <div class="card feature-card">
          <div class="icon-wrapper">🚨</div>
          <h3>Plomberie d'Urgence</h3>
          <p>Une fuite au milieu de la nuit ? Notre équipe est disponible 24h/24 et 7j/7.</p>
        </div>
        <div class="card feature-card">
          <div class="icon-wrapper">💯</div>
          <h3>Professionnels Agréés</h3>
          <p>Une équipe de plombiers et chauffagistes certifiés pour un travail dans les normes.</p>
        </div>
        <div class="card feature-card">
          <div class="icon-wrapper">✅</div>
          <h3>Travail Garanti</h3>
          <p>Nous utilisons du matériel de pointe et offrons une garantie sur toutes nos réparations.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Trust Badges (Brands & Certs) -->
  <section class="trust-brands bg-white" style="padding: 40px 0; border-bottom: 1px solid #eaeaea;">
    <div class="container text-center">
      <p class="text-muted text-sm font-bold uppercase tracking-wider mb-6">Installateur Agréé & Marques Partenaires</p>
      <div class="flex flex-wrap justify-center items-center gap-8 opacity-70" style="opacity: 0.6;">
        <span class="font-bold text-xl text-secondary" style="font-size: 1.5rem; margin: 0 15px;">CERGA</span>
        <span class="font-bold text-xl text-secondary" style="font-size: 1.5rem; margin: 0 15px;">Vaillant</span>
        <span class="font-bold text-xl text-secondary" style="font-size: 1.5rem; margin: 0 15px;">Bulex</span>
        <span class="font-bold text-xl text-secondary" style="font-size: 1.5rem; margin: 0 15px;">Viessmann</span>
        <span class="font-bold text-xl text-secondary" style="font-size: 1.5rem; margin: 0 15px;">Grohe</span>
        <span class="font-bold text-xl text-secondary" style="font-size: 1.5rem; margin: 0 15px;">Geberit</span>
      </div>
    </div>
  </section>

  <!-- Services Preview -->
  <section class="section services-preview bg-accent">
    <div class="container">
      <div class="flex justify-between items-center mb-12">
        <div>
          <span class="text-primary font-bold uppercase text-sm">Nos Services</span>
          <h2>Un service d'excellence</h2>
        </div>
        <a href="/services" class="btn btn-secondary">Voir tous les services</a>
      </div>
      <div class="grid service-grid">
        <div class="service-card">
          <img src="/images/service.png" alt="Réparation Plomberie" />
          <div class="service-content">
            <h3>Dépannage Plomberie</h3>
            <p>Réparation de fuites, remplacement de robinetterie et installation sanitaire complète.</p>
            <a href="/services" class="text-primary font-bold mt-4 inline-block">En savoir plus →</a>
          </div>
        </div>
        <div class="service-card">
          <img src="/images/hero.png" alt="Débouchage" />
          <div class="service-content">
            <h3>Débouchage Canalisation</h3>
            <p>Curage haute pression pour vos éviers, toilettes et égouts bouchés.</p>
            <a href="/services" class="text-primary font-bold mt-4 inline-block">En savoir plus →</a>
          </div>
        </div>
        <div class="service-card">
          <img src="/images/service.png" alt="Chauffage" />
          <div class="service-content">
            <h3>Entretien Chauffage</h3>
            <p>Entretien et réparation de chaudières toutes marques pour votre confort.</p>
            <a href="/services" class="text-primary font-bold mt-4 inline-block">En savoir plus →</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Team / About Preview -->
  <section class="section team">
    <div class="container text-center">
      <span class="text-primary font-bold uppercase text-sm">Notre Équipe</span>
      <h2 class="mb-12">Réparation et Précision</h2>
      <div class="grid team-grid">
        <div class="team-member">
          <div class="team-img-wrapper">
            <img src="/images/team.png" alt="Membre équipe" />
          </div>
          <h4 class="mt-4">Thomas D.</h4>
          <p>Plombier Expert</p>
        </div>
        <div class="team-member">
          <div class="team-img-wrapper">
            <img src="/images/team.png" alt="Membre équipe" />
          </div>
          <h4 class="mt-4">Marc L.</h4>
          <p>Chauffagiste Agréé</p>
        </div>
        <div class="team-member">
          <div class="team-img-wrapper">
            <img src="/images/team.png" alt="Membre équipe" />
          </div>
          <h4 class="mt-4">Julien S.</h4>
          <p>Spécialiste Débouchage</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats Counter & Response Time -->
  <section class="section stats bg-primary text-light">
    <div class="container grid stats-grid text-center">
      <div>
        <h2 class="text-white text-5xl">30m</h2>
        <p class="text-accent mt-2">Temps de Réponse</p>
      </div>
      <div>
        <h2 class="text-white text-5xl">11k+</h2>
        <p class="text-accent mt-2">Interventions</p>
      </div>
      <div>
        <h2 class="text-white text-5xl">15+</h2>
        <p class="text-accent mt-2">Années d'Expérience</p>
      </div>
      <div>
        <h2 class="text-white text-5xl">100%</h2>
        <p class="text-accent mt-2">Clients Satisfaits</p>
      </div>
    </div>
  </section>

  <!-- Testimonials & Review Badges -->
  <section class="section testimonials bg-light">
    <div class="container text-center">
      <span class="text-primary font-bold uppercase text-sm">Témoignages & Avis</span>
      <h2>Ce que disent nos clients</h2>
      
      <div class="review-badges flex justify-center items-center gap-6 mt-6 mb-12 flex-wrap">
        <div class="badge-box bg-white p-4 rounded shadow-sm flex items-center gap-3" style="background: white; padding: 15px 25px; border-radius: 8px; box-shadow: 0 4px 15px rgba(0,0,0,0.05); border: 1px solid #eaeaea;">
          <div class="text-3xl font-bold" style="color: #4285F4; font-size: 2rem;">G</div>
          <div class="text-left" style="text-align: left;">
            <div class="stars text-primary text-sm" style="font-size: 0.9rem;">⭐⭐⭐⭐⭐</div>
            <div class="font-bold text-secondary" style="font-weight: bold;">4.9/5 Avis Google</div>
          </div>
        </div>
        <div class="badge-box bg-white p-4 rounded shadow-sm flex items-center gap-3" style="background: white; padding: 15px 25px; border-radius: 8px; box-shadow: 0 4px 15px rgba(0,0,0,0.05); border: 1px solid #eaeaea;">
          <div class="text-3xl text-green-500 font-bold" style="color: #00b67a; font-size: 2rem;">★</div>
          <div class="text-left" style="text-align: left;">
            <div class="stars text-primary text-sm" style="font-size: 0.9rem;">⭐⭐⭐⭐⭐</div>
            <div class="font-bold text-secondary" style="font-weight: bold;">Excellent Trustpilot</div>
          </div>
        </div>
      </div>
      <div class="grid testimonial-grid">
        <div class="card testimonial-card">
          <div class="stars text-primary mb-4">⭐⭐⭐⭐⭐</div>
          <p class="italic mb-6">"Une équipe réactive et professionnelle. Ils sont intervenus un dimanche soir pour une fuite importante dans notre salle de bain. Travail impeccable et prix correct."</p>
          <h4>Sophie M.</h4>
          <span class="text-sm">Charleroi Centre</span>
        </div>
        <div class="card testimonial-card">
          <div class="stars text-primary mb-4">⭐⭐⭐⭐⭐</div>
          <p class="italic mb-6">"Mon égout était bouché depuis des jours. Ils ont utilisé une caméra pour trouver le problème et ont tout nettoyé rapidement. Très satisfait."</p>
          <h4>Luc V.</h4>
          <span class="text-sm">Gosselies</span>
        </div>
        <div class="card testimonial-card">
          <div class="stars text-primary mb-4">⭐⭐⭐⭐⭐</div>
          <p class="italic mb-6">"Entretien de ma chaudière Bulex fait avec sérieux. Le technicien a pris le temps d'expliquer ce qu'il faisait. Je recommande Dépannage Plombier Charleroi sans hésiter."</p>
          <h4>Antoine R.</h4>
          <span class="text-sm">Jumet</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Service Area Map -->
  <section class="section map-section">
    <div class="container">
      <div class="text-center mb-12">
        <span class="text-primary font-bold uppercase text-sm">Proximité & Intervention</span>
        <h2>Notre Zone de Couverture</h2>
        <p class="text-muted mt-4 max-w-2xl mx-auto" style="max-width: 800px; margin: 1rem auto 0;">Nous intervenons rapidement sur tout le Grand Charleroi et sa périphérie. Grâce à notre position stratégique, nos techniciens sont sur place en moyenne en 30 minutes lors d'une urgence.</p>
      </div>
      <div class="map-container" style="border-radius: var(--border-radius); overflow: hidden; height: 400px; box-shadow: var(--box-shadow); border: 2px solid var(--accent);">
        <iframe 
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d81248.51468603504!2d4.364379361664156!3d50.42858167886477!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x47c225e3612f00f5%3A0x40099ab2f4d5460!2sCharleroi!5e0!3m2!1sfr!2sbe!4v1700000000000!5m2!1sfr!2sbe" 
          width="100%" 
          height="100%" 
          style="border:0;" 
          allowfullscreen="" 
          loading="lazy" 
          referrerpolicy="no-referrer-when-downgrade">
        </iframe>
      </div>
    </div>
  </section>
</Layout>

<style>
  .hero {
    position: relative;
    padding: 80px 0 120px;
    overflow: hidden;
  }
  
  .hero-bg-shape {
    position: absolute;
    top: 0;
    right: 0;
    width: 45%;
    height: 100%;
    background: var(--secondary);
    border-top-left-radius: 300px;
    border-bottom-left-radius: 300px;
    z-index: 0;
  }
  
  .hero-container {
    grid-template-columns: 1.2fr 0.8fr;
    gap: 40px;
    align-items: center;
    position: relative;
    z-index: 10;
  }
  
  .hero-content {
    position: relative;
    z-index: 10;
  }
  
  .hero-image {
    position: relative;
    z-index: 10;
  }
  
  .mt-8 { margin-top: 2rem; }
  .mb-12 { margin-bottom: 3rem; }
  .mb-4 { margin-bottom: 1rem; }
  .mb-6 { margin-bottom: 1.5rem; }
  
  .image-wrapper {
    position: relative;
    border-radius: 50%;
    padding: 20px;
    background: white;
    box-shadow: var(--box-shadow);
  }
  
  .image-wrapper img {
    border-radius: 50%;
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
  }
  
  .stats-float {
    position: absolute;
    bottom: 20px;
    left: -30px;
    padding: 15px 25px;
    border-radius: 20px;
    z-index: 2;
  }
  
  .feature-grid {
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 30px;
  }
  
  .icon-wrapper {
    width: 60px;
    height: 60px;
    background: var(--accent);
    color: var(--primary);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 24px;
    margin-bottom: 20px;
  }
  
  .bg-accent { background: var(--accent); }
  .bg-primary { background: var(--primary); }
  .text-white { color: white; }
  .text-accent { color: var(--accent); }
  .text-5xl { font-size: 3rem; }
  
  .service-grid {
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 30px;
  }
  
  .service-card {
    background: white;
    border-radius: var(--border-radius);
    overflow: hidden;
    box-shadow: var(--box-shadow);
    transition: var(--transition);
  }
  
  .service-card:hover {
    transform: translateY(-10px);
  }
  
  .service-card img {
    width: 100%;
    height: 250px;
    object-fit: cover;
  }
  
  .service-content {
    padding: 30px;
  }
  
  .team-grid {
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 40px;
    justify-content: center;
  }
  
  .team-img-wrapper {
    width: 200px;
    height: 200px;
    margin: 0 auto;
    border-radius: 50%;
    overflow: hidden;
    border: 5px solid var(--accent);
  }
  
  .team-img-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  
  .stats-grid {
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 30px;
  }
  
  .testimonial-grid {
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 30px;
  }
  
  @media (max-width: 992px) {
    .hero-container {
      grid-template-columns: 1fr;
    }
    .hero-bg-shape {
      width: 100%;
      height: 50%;
      top: auto;
      bottom: 0;
      border-bottom-left-radius: 0;
      border-top-right-radius: 100px;
    }
  }
</style>
