---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact | Dépannage Plombier Charleroi">
  <section class="section bg-secondary text-white text-center" style="background: var(--secondary); padding: 100px 0;">
    <div class="container">
      <h1 class="text-white">Contactez-nous</h1>
      <p class="text-accent mt-4">Nous sommes disponibles 24/7 pour vos urgences à Charleroi.</p>
    </div>
  </section>

  <section class="section">
    <div class="container grid" style="grid-template-columns: 1fr 1fr; gap: 60px;">
      <div>
        <span class="text-primary font-bold uppercase text-sm">Prendre Contact</span>
        <h2 class="mt-4 mb-8">Demander une Intervention</h2>
        
        <form class="contact-form">
          <div class="form-group">
            <label>Nom complet</label>
            <input type="text" placeholder="Votre nom" />
          </div>
          <div class="form-group">
            <label>Téléphone</label>
            <input type="tel" placeholder="Votre numéro" />
          </div>
          <div class="form-group">
            <label>Service souhaité</label>
            <select>
              <option>Plomberie (Fuite, Réparation)</option>
              <option>Débouchage</option>
              <option>Chauffage</option>
              <option>Autre</option>
            </select>
          </div>
          <div class="form-group">
            <label>Message</label>
            <textarea rows="4" placeholder="Décrivez votre problème..."></textarea>
          </div>
          <button type="submit" class="btn btn-primary w-full" style="width: 100%;">Envoyer la demande</button>
        </form>
      </div>
      
      <div class="contact-details">
        <div class="card mb-6">
          <h3 class="text-secondary">📍 Notre Adresse</h3>
          <p class="mt-2 text-muted"><a href="https://maps.app.goo.gl/wLrCE3QZhcmmRTW98" target="_blank" rel="noopener noreferrer" style="color: inherit; text-decoration: none; font-weight: bold;">Av. des Alliés 42, 6000 Charleroi</a><br />(Intervention dans tout le Hainaut)</p>
        </div>
        <div class="card mb-6">
          <h3 class="text-secondary">📞 Téléphone</h3>
          <p class="mt-2 text-muted">Urgences 24/7: <strong class="text-primary">0479 12 34 56</strong></p>
        </div>
        <div class="card mb-6">
          <h3 class="text-secondary">✉️ Email</h3>
          <p class="mt-2 text-muted">contact@depannageplombiercharleroi.be</p>
        </div>
        <div class="card bg-accent mt-8">
          <h3 class="text-primary">Service d'Urgence 24/7</h3>
          <p class="mt-2 text-secondary">En cas de fuite importante ou de canalisation totalement bouchée, appelez-nous directement. Un technicien partira immédiatement.</p>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .text-white { color: white; }
  .text-accent { color: var(--accent); }
  .text-secondary { color: var(--secondary); }
  .mt-2 { margin-top: 0.5rem; }
  .mt-4 { margin-top: 1rem; }
  .mt-8 { margin-top: 2rem; }
  .mb-6 { margin-bottom: 1.5rem; }
  .mb-8 { margin-bottom: 2rem; }
  .text-muted { color: var(--text-muted); }
  .bg-accent { background: var(--accent); }
  
  .contact-form .form-group {
    margin-bottom: 20px;
  }
  
  .contact-form label {
    display: block;
    margin-bottom: 8px;
    font-weight: 600;
    color: var(--secondary);
  }
  
  .contact-form input,
  .contact-form select,
  .contact-form textarea {
    width: 100%;
    padding: 12px 16px;
    border: 1px solid #ddd;
    border-radius: 8px;
    font-family: inherit;
    font-size: 1rem;
    transition: var(--transition);
  }
  
  .contact-form input:focus,
  .contact-form select:focus,
  .contact-form textarea:focus {
    outline: none;
    border-color: var(--primary);
    box-shadow: 0 0 0 3px rgba(0, 102, 255, 0.1);
  }
  
  @media (max-width: 768px) {
    .grid { grid-template-columns: 1fr !important; }
  }
</style>
